# Copia este archivo como .env y completa los valores

# Base de datos (por defecto SQLite local)
DATABASE_URL=sqlite:///./ips_cuidando.db

# Seguridad JWT - Cambia este valor en producción
SECRET_KEY=cambia-esta-clave-secreta-en-produccion-usa-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Datos de la IPS (para reportes RIPS)
IPS_NIT=900000000
IPS_NOMBRE=CUIDANDO DE TI CyE IPS SAS
IPS_MUNICIPIO=76001
IPS_CODIGO_HABILITACION=760010000000

# CORS - Orígenes permitidos (separados por coma)
# Incluir el sitio web público para que el agendamiento funcione desde el frontend
CORS_ORIGINS=http://localhost:4200,http://localhost:3000,https://ipscuidandodeti.com
